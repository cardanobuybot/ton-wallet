# Порт и хост HTTP-сервера
PORT=3000
HOST=127.0.0.1
# Toncenter (testnet по умолчанию); ключ опционален — бесплатный лимит без ключа
TONCENTER_BASE=https://testnet.toncenter.com/api/v2
TONCENTER_API_KEY=
TONCENTER_TIMEOUT_MS=10000
# CORS: только локальные ориджины
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173
